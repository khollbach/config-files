#!/usr/bin/python3
#
# Simple pomodoro timer script.
#
# E.g.:
# $ timer 25

import datetime
import sys
import time

def main():
    assert len(sys.argv) == 2, 'expected one argument: number of minutes'
    mins = int(sys.argv[1])
    assert mins >= 0
    secs = 60 * mins

    while secs >= 0:
        m = str(secs // 60)
        if len(m) < 2:
            m = ' ' + m
        s = str(secs % 60)
        if len(s) < 2:
            s = '0' + s

        clear()
        print(f'{m}:{s}')

        time.sleep(1)

        secs -= 1

    now = datetime.datetime.now()
    print(f'finished at {now}')

def clear():
    for _ in range(200):
        print()

if __name__ == '__main__':
    main()
